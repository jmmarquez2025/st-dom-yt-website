# St. Dominic Website — Environment Configuration
# Copy this file to .env and fill in the values.
# All variables use the VITE_ prefix (required by Vite for client-side access).

# Google Apps Script URL for the contact form (leave empty to fall back to mailto)
VITE_CONTACT_FORM_URL=

# Google Apps Script URL for the registration form (leave empty for mailto fallback)
VITE_REGISTRATION_FORM_URL=

# Optional CORS proxy in front of the form endpoints (Cloudflare Worker, etc).
# When set, the contact + registration forms switch to CORS mode and surface
# real success/error responses from the server. See cms/contact-proxy.js for a
# deployable Cloudflare Worker template. Leave empty to keep no-cors mode.
VITE_FORM_PROXY_URL=

# Google Sheets CMS — published Sheet ID (see config.js for setup instructions)
VITE_CMS_SHEET_ID=

# Blog CMS — Google Apps Script URL serving blog posts from Google Docs
# See cms/blog-cms.gs for setup instructions
VITE_BLOG_CMS_URL=

# Admin CMS — Google Apps Script URL backing the Staff Dashboard sync
# See cms/admin-cms.gs for setup instructions
VITE_ADMIN_CMS_URL=

# Public Flocknote giving page URL. Do not use the admin/action-center URL.
VITE_FLOCKNOTE_GIVING_URL=https://stdominicchurch.flocknote.com/give

# Legacy alias still supported by config.js for older deployments.
VITE_WESHARE_URL=

# Plausible analytics domain. Use current host until parish-domain transfer.
VITE_PLAUSIBLE_DOMAIN=jmmarquez2025.github.io

# YouTube channel ID / embed URL for streaming
VITE_YOUTUBE_CHANNEL_ID=
VITE_YOUTUBE_EMBED_URL=

# Flipbook bulletin embed URL (FlipHTML5, Heyzine, Issuu, etc.)
VITE_BULLETIN_URL=

# Canonical site URL used for sitemap, robots.txt, Open Graph, and JSON-LD
VITE_SITE_URL=https://jmmarquez2025.github.io/st-dom-yt-website

# Staff Dashboard passphrase (soft gate, not real auth — the value is in the
# client bundle). Defaults to "veritas" if unset; override here to change it
# without editing source. Whatever you set, also update docs/admin-guide.md.
VITE_STAFF_PASSPHRASE=
